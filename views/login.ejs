<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - AIDA Desa Parit Baru</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap');
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: radial-gradient(circle at top, #f0f9ff 0%, #e0f2fe 100%); }
        .glass { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.3); }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">

    <div class="glass w-full max-w-md rounded-[40px] shadow-2xl p-10">
        <div class="text-center mb-10">
            <img src="/logo-desa.png" alt="Logo" class="w-20 h-20 mx-auto mb-4 drop-shadow-lg">
            <h1 class="text-2xl font-extrabold text-blue-800">Selamat Datang</h1>
            <p class="text-slate-500 text-sm mt-2">Masuk untuk akses tanpa batas ke AI Layanan Desa</p>
        </div>

        <form id="loginForm" class="space-y-6">
            <div>
                <label class="block text-xs font-bold text-blue-800 uppercase tracking-widest mb-2 ml-1">Username</label>
                <input type="text" id="username" required 
                    class="w-full px-5 py-4 rounded-2xl border border-slate-200 focus:border-blue-400 focus:ring-4 focus:ring-blue-100 outline-none transition-all"
                    placeholder="Masukkan username Anda">
            </div>

            <div>
                <label class="block text-xs font-bold text-blue-800 uppercase tracking-widest mb-2 ml-1">Password</label>
                <input type="password" id="password" required 
                    class="w-full px-5 py-4 rounded-2xl border border-slate-200 focus:border-blue-400 focus:ring-4 focus:ring-blue-100 outline-none transition-all"
                    placeholder="••••••••">
            </div>

            <button type="submit" 
                class="w-full bg-blue-600 text-white py-4 rounded-2xl font-bold shadow-lg shadow-blue-200 hover:bg-blue-700 hover:scale-[1.02] active:scale-[0.98] transition-all">
                Masuk Sekarang
            </button>
        </form>

        <div class="mt-8 text-center">
            <a href="/" class="text-sm font-semibold text-blue-600 hover:underline">← Kembali ke Chat (Mode Tamu)</a>
        </div>
    </div>

    <script>
        // const API_URL = "http://localhost:3000/api"; // URL Backend Port 3000
        // Mengambil nilai backendUrl yang dikirim dari server.js via EJS
        const API_URL = "<%= backendUrl %>";

        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const username = document.getElementById('username').value;
            const password = document.getElementById('password').value;

            try {
                // Tampilkan loading
                Swal.fire({ title: 'Memverifikasi...', allowOutsideClick: false, didOpen: () => { Swal.showLoading() } });

                // Request ke Backend Port 3000
                const response = await axios.post(`${API_URL}/chat/login`, { username, password });

                if (response.data.success) {
                    // Simpan data login ke Cookie (berlaku 1 hari)
                    const userData = JSON.stringify({
                        token: response.data.token,
                        role: response.data.role,
                        nama: response.data.user.nama
                    });

                    // Set Cookie manual agar bisa dibaca server & client
                    document.cookie = `user_data=${encodeURIComponent(userData)}; path=/; max-age=86400`;

                    Swal.fire({
                        icon: 'success',
                        title: 'Berhasil Masuk!',
                        text: `Halo, ${response.data.user.nama}. Selamat bertugas!`,
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => {
                        window.location.href = '/'; // Kembali ke halaman Chat
                    });
                }
            } catch (err) {
                Swal.fire({
                    icon: 'error',
                    title: 'Gagal Login',
                    text: err.response?.data?.message || 'Terjadi kesalahan pada server.'
                });
            }
        });
    </script>
    <script>
        // Cek cookie di sisi client
        if (document.cookie.split('; ').find(row => row.startsWith('user_data='))) {
            window.location.href = '/';
        }
    </script>
</body>
</html>